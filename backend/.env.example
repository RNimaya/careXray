# Copy this file to .env and fill in the values
# cp .env.example .env

ENCRYPTION_KEY=your_fernet_key_here
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Railway: paste the complete Firebase service account JSON as a variable.
# Local alternative: keep backend/firebase-service-account-key.json on your machine only.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
